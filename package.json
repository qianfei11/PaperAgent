{
  "name": "paper-agent",
  "version": "0.1.0",
  "description": "A graphical tool for LLM interaction with context management and document association",
  "main": "./dist/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.main.json && node copy-js.cjs && electron-builder",
    "build:win": "tsc -p tsconfig.json && tsc -p tsconfig.main.json && node copy-js.cjs && electron-builder --win",
    "build:mac": "tsc -p tsconfig.json && tsc -p tsconfig.main.json && node copy-js.cjs && electron-builder --mac",
    "build:linux": "tsc -p tsconfig.json && tsc -p tsconfig.main.json && node copy-js.cjs && electron-builder --linux",
    "compile": "tsc -p tsconfig.json && tsc -p tsconfig.main.json && node copy-js.cjs",
    "watch": "tsc --watch",
    "electron-dev": "electron --disable-web-security --allow-running-insecure-content . --dev"
  },
  "keywords": [
    "llm",
    "ai",
    "chat",
    "academic",
    "research",
    "electron",
    "typescript"
  ],
  "author": "PaperAgent Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/uuid": "^10.0.0",
    "electron": "^25.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "lowdb": "^6.0.0",
    "pdfjs-dist": "^3.0.0",
    "tesseract.js": "^4.0.0",
    "uuid": "^13.0.0"
  },
  "build": {
    "appId": "com.paperagent.app",
    "productName": "PaperAgent",
    "afterPack": "after-pack.cjs",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "assets/**/*",
      "!dist/*.AppImage",
      "!dist/*.snap",
      "!dist/*.deb",
      "!dist/*.rpm",
      "!dist/*.dmg",
      "!dist/*.exe",
      "!dist/*.blockmap",
      "!dist/latest*.yml",
      "!dist/builder-debug.yml",
      "!dist/builder-effective-config.yaml",
      "!dist/linux-unpacked/**/*",
      "!dist/win-unpacked/**/*",
      "!dist/mac/**/*",
      "!dist/mac-arm64/**/*",
      "!dist/mac-universal/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icons/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icons/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icons/icon.png",
      "executableArgs": [
        "--no-sandbox"
      ]
    }
  }
}
